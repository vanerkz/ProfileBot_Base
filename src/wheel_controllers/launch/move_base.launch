<launch>
  <!-- Arguments -->
  <arg name="cmd_vel_topic" default="/cmd_vel"/>
  <arg name="odom_topic" default="odom"/>
  <arg name="move_forward_only" default="false"/>

  <!-- move_base node -->
  <node pkg="move_base" type="move_base" name="move_base" respawn="false" output="screen">
    
    <param name="use_sim_time" value="true"/>
    <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>

    <!-- Load costmap parameters -->
    <rosparam file="$(find wheel_controllers)/param/costmap_common_params.yaml" command="load" ns="global_costmap"/>
    <rosparam file="$(find wheel_controllers)/param/costmap_common_params.yaml" command="load" ns="local_costmap"/>
    <rosparam file="$(find wheel_controllers)/param/local_costmap_params.yaml" command="load"/>
    <rosparam file="$(find wheel_controllers)/param/global_costmap_params.yaml" command="load"/>
    <rosparam file="$(find wheel_controllers)/param/dwa_local_planner_params.yaml" command="load"/>
    <rosparam file="$(find wheel_controllers)/param/move_base.yaml" command="load"/>

    <!-- Remap topics -->
    <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
    <remap from="odom" to="$(arg odom_topic)"/>
    

    <param name="DWAPlannerROS/min_vel_x" value="0.0" if="$(arg move_forward_only)"/>
  </node>
</launch>
