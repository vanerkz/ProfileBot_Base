<?xml version="1.0"?>
<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>

  <xacro:property name="arm_id" value="servo" />
  <xacro:property name="description_pkg" value="package://my_robot_gazebo" />

  <!-- Base Link -->
<link name="base_link">
  <inertial>
    <mass value="5.0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
  </inertial>
  <visual>
    <origin rpy="0 0 3.14" xyz="0 0 0"/>
    <geometry>
      <mesh filename="${description_pkg}/meshes/base_link.stl"/>
    </geometry>
  </visual>
</link>

<link name="world_link"/>


<!-- Back Caster Wheel -->
<link name="back_wheel">
  <inertial>
    <mass value="0.1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 1.5708 0"/> <!-- wheel spins along local Y -->
    <geometry>
      <cylinder radius="0.0485" length="0.05"/>
    </geometry>
    <material name="blue"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 1.5708 0"/>
    <geometry>
      <cylinder radius="0.0485" length="0.05"/>
    </geometry>
  </collision>
</link>

<!-- Swivel joint for the caster -->
<joint name="back_swivel_joint" type="continuous">
  <parent link="base_link"/>
  <child link="back_wheel"/>
  <origin xyz="-0.18 0 0.0485" rpy="0 0 0"/> <!-- positioned behind main wheels -->
  <axis xyz="0 0 1"/> <!-- swivel freely around vertical Z-axis -->
</joint>

<!-- LEFT WHEEL LINK -->
<link name="left_wheel">
  <inertial>
    <mass value="0.5"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
  </inertial>

  <visual>
    <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.0485" length="0.05"/>
    </geometry>
    <material name="blue"/>
  </visual>

  <collision>
    <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.0485" length="0.05"/>
    </geometry>
  </collision>
</link>


<!-- RIGHT WHEEL LINK -->
<link name="right_wheel">
  <inertial>
    <mass value="0.5"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
  </inertial>

  <visual>
    <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.0485" length="0.05"/>
    </geometry>
    <material name="blue"/>
  </visual>

  <collision>
    <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.0485" length="0.05"/>
    </geometry>
  </collision>
</link>


<!-- LEFT WHEEL JOINT -->
<joint name="left_wheel_joint" type="continuous">
  <parent link="base_link"/>
  <child link="left_wheel"/>
  <origin xyz="0.08 0.155 0.0485" rpy="0 0 0"/>
  <axis xyz="0 1 0"/>
  <limit effort="100.0" velocity="50.0"/>
  <dynamics damping="0.2" friction="0.2"/>
</joint>


<!-- RIGHT WHEEL JOINT -->
<joint name="right_wheel_joint" type="continuous">
  <parent link="base_link"/>
  <child link="right_wheel"/>
  <origin xyz="0.08 -0.155 0.0485" rpy="0 0 0"/>
  <axis xyz="0 1 0"/>
  <limit effort="100.0" velocity="50.0"/>
  <dynamics damping="0.2" friction="0.2"/>
</joint>


<!-- WHEEL GROUND FRICTION -->
<gazebo reference="left_wheel">
  <mu1>5.0</mu1>
  <mu2>5.0</mu2>
  <kp>1000000.0</kp>
  <kd>1.0</kd>
</gazebo>

<gazebo reference="right_wheel">
  <mu1>5.0</mu1>
  <mu2>5.0</mu2>
  <kp>1000000.0</kp>
  <kd>1.0</kd>
</gazebo>

  <!-- Laser -->
  <link name="laser">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.04"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.02" radius="0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0 0 0.11" rpy="0 0 0"/>
  </joint>

  <!-- Head Base Link -->
  <link name="head_base_link">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="${description_pkg}/meshes/headjoint_0.stl"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="${description_pkg}/meshes/headjoint_0.stl"/>
      </geometry>
    </collision>
  </link>

  <joint name="headjoint_base" type="fixed">
    <parent link="base_link"/>
    <child link="head_base_link"/>
    <origin rpy="0 0 0" xyz="0.015 0 1.02916"/>
  </joint>

  <!-- Arm Links -->
  <xacro:macro name="arm_link" params="i mesh_file mass_value">
    <link name="${arm_id}_${i}">
      <inertial>
        <mass value="${mass_value}"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="${description_pkg}/meshes/${mesh_file}"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="${description_pkg}/meshes/${mesh_file}"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- Arm Joints -->
  <xacro:macro name="arm_joint" params="i parent_link axis_xyz origin_xyz lower upper">
    <joint name="joint_${i}" type="revolute">
      <axis xyz="${axis_xyz}"/>
      <parent link="${parent_link}"/>
      <child link="${arm_id}_${i}"/>
      <origin xyz="${origin_xyz}" rpy="0 0 0"/>
      <limit effort="100" velocity="3" lower="${lower}" upper="${upper}"/>
      <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="${lower}" soft_upper_limit="${upper}"/>
    </joint>
  </xacro:macro>
  
  <xacro:macro name="arm_joint_rotate" params="i parent_link axis_xyz origin_xyz origin_rpy lower upper">
  <joint name="joint_${i}" type="revolute">
    <axis xyz="${axis_xyz}"/>
    <parent link="${parent_link}"/>
    <child link="${arm_id}_${i}"/>
    <origin xyz="${origin_xyz}" rpy="${origin_rpy}"/>
    <limit effort="100" velocity="3" lower="${lower}" upper="${upper}"/>
  </joint>
</xacro:macro>

  <!-- Arm Link and Joint Examples -->
<xacro:arm_link i="0" mesh_file="joint_1_0.stl" mass_value="0.5"/>
<xacro:arm_joint_rotate 
    i="0" 
    parent_link="base_link" 
    axis_xyz="0 0 -1" 
    origin_xyz="0.015 0 0.67475" 
    origin_rpy="0 0 3.14159"
    lower="-2.15" 
    upper="2.15"/>

  <xacro:arm_link i="1" mesh_file="joint_2_1.stl" mass_value="0.4"/>
  <xacro:arm_joint i="1" parent_link="${arm_id}_0" axis_xyz="0 0 1" origin_xyz="0.10035 0 0.1002" lower="-1.57" upper="1.57"/>

  <xacro:arm_link i="2" mesh_file="joint_3_2.stl" mass_value="0.3"/>
  <xacro:arm_joint i="2" parent_link="${arm_id}_1" axis_xyz="0 -1 0" origin_xyz="0.056 0 0.0325" lower="-1.35" upper="1.6"/>

  <xacro:arm_link i="3" mesh_file="joint_4_3.stl" mass_value="0.3"/>
  <xacro:arm_joint i="3" parent_link="${arm_id}_2" axis_xyz="1 0 0" origin_xyz="0.1155 0.0175 0" lower="-1.6" upper="1.6"/>

  <xacro:arm_link i="4" mesh_file="joint_5_4.stl" mass_value="0.3"/>
  <xacro:arm_joint i="4" parent_link="${arm_id}_3" axis_xyz="0 -1 0" origin_xyz="0.16911 -0.01413 -0.00487" lower="-1.6" upper="1.6"/>

  <xacro:arm_link i="5" mesh_file="joint_6_5_new.stl" mass_value="0.2"/>
  <xacro:arm_joint i="5" parent_link="${arm_id}_4" axis_xyz="0 0 -1" origin_xyz="0.05118 -0.016 -0.0231" lower="-1.6" upper="1.6"/>

  <xacro:arm_link i="6" mesh_file="joint_7_6_new.stl" mass_value="0.2"/>
  <xacro:arm_joint i="6" parent_link="${arm_id}_5" axis_xyz="-1 0 0" origin_xyz="-0.01886 0 -0.2255" lower="-2.3" upper="2.3"/>

  <xacro:arm_link i="7" mesh_file="hook_new.stl" mass_value="0.1"/>
  <xacro:arm_joint i="7" parent_link="${arm_id}_6" axis_xyz="0 0 -1" origin_xyz="-0.02307 -0.012 -0.02368" lower="-3.14" upper="3.14"/>

  <!-- Head Links -->
  <xacro:arm_link i="8" mesh_file="headjoint_1_0.stl" mass_value="0.2"/>
  <xacro:arm_joint i="8" parent_link="head_base_link" axis_xyz="0 0 1" origin_xyz="0 0 0.0555" lower="-3.14" upper="3.14"/>

  <xacro:arm_link i="9" mesh_file="headjoint_2_1.stl" mass_value="0.2"/>
  <xacro:arm_joint i="9" parent_link="${arm_id}_8" axis_xyz="0 -1 0" origin_xyz="0 0 0.0425" lower="-0.4" upper="0.4"/>

  <!-- RealSense Camera -->
  <xacro:arg name="use_nominal_extrinsics" default="false"/>
  <xacro:include filename="$(find realsense2_description)/urdf/_d435.urdf.xacro" />
  
  <link name="realsense_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <xacro:sensor_d435 parent="realsense_link" use_nominal_extrinsics="$(arg use_nominal_extrinsics)">
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:sensor_d435>

  <joint name="joint_realsense" type="fixed">
    <parent link="${arm_id}_9"/>
    <child link="realsense_link"/>
    <origin rpy="0 0 0" xyz="0.06527 0 0.015"/>
  </joint>
  
    <!-- Add this just before the closing </robot> tag -->


<!-- Transmissions for all arm and head joints -->
<transmission name="joint_0_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="joint_0">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="joint_0_motor">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<transmission name="joint_1_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="joint_1">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="joint_1_motor">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<!-- Repeat for joint_2 to joint_7 -->
<transmission name="joint_2_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="joint_2">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="joint_2_motor">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<!-- Arm joints continue -->
<transmission name="joint_3_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="joint_3">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="joint_3_motor">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<transmission name="joint_4_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="joint_4">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="joint_4_motor">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<transmission name="joint_5_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="joint_5">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="joint_5_motor">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<transmission name="joint_6_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="joint_6">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="joint_6_motor">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<transmission name="joint_7_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="joint_7">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="joint_7_motor">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<!-- Head joints -->
<transmission name="joint_8_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="joint_8">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="joint_8_motor">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<transmission name="joint_9_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="joint_9">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="joint_9_motor">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<transmission name="left_wheel_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="left_wheel_joint">
    <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
  </joint>
  <actuator name="left_wheel_motor">
    <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<transmission name="right_wheel_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="right_wheel_joint">
    <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
  </joint>
  <actuator name="right_wheel_motor">
    <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<gazebo>
  <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
    <robotNamespace>/</robotNamespace>
    <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
  </plugin>
</gazebo>

<gazebo reference="laser">
  <sensor type="ray" name="rplidar">
    <pose>0 0 0 0 0 0</pose>
    <visualize>true</visualize>
    <update_rate>10</update_rate>

    <ray>
      <scan>
        <horizontal>
          <samples>720</samples>
          <resolution>1</resolution>
          <min_angle>-3.14159</min_angle>
          <max_angle>3.14159</max_angle>
        </horizontal>
      </scan>

      <range>
        <min>0.16</min>
        <max>8.0</max>
        <resolution>0.01</resolution>
      </range>

      <noise>
        <type>gaussian</type>
        <mean>0.0</mean>
        <stddev>0.01</stddev>
      </noise>
    </ray>

    <plugin name="gazebo_ros_laser" filename="libgazebo_ros_laser.so">
      <topicName>/scan</topicName>
      <frameName>laser</frameName>
      <updateRate>10.0</updateRate>
    </plugin>
  </sensor>
</gazebo>


</robot>


